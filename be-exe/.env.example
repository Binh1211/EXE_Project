# MongoDB Atlas — lấy connection string từ https://cloud.mongodb.com
# Database Access: tạo user + password
# Network Access: thêm IP dev hoặc IP VPS production
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vistory?retryWrites=true&w=majority

PORT=8080
NODE_ENV=development

# JWT — production secrets must be real random strings, at least 32 chars
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend (CORS + link trong email reset mật khẩu)
# Backend-only deploy keeps local frontend origin until a frontend domain exists.
CLIENT_URL=http://localhost:5173

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Local redirect URI: http://localhost:8080/api/auth/google/callback
# Production redirect URI: https://api-vistory.treklink.site/api/auth/google/callback
# Authorized JavaScript origins: http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# SMTP (gửi email quên mật khẩu) — có thể dùng Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vistory <noreply@example.com>"
