# MongoDB Atlas — lấy connection string từ https://cloud.mongodb.com
# Database Access: tạo user + password
# Network Access: thêm IP (0.0.0.0/0 cho dev)
MONGODB_URI=mongodb+srv://hoangcongbinh121104_db_user:EIdZB6UtjSMEandP@cluster0.gqdn6ex.mongodb.net/?appName=Cluster0

PORT=8080
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend (CORS + link trong email reset mật khẩu)
CLIENT_URL=http://localhost:5173

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/api/auth/google/callback
# Authorized JavaScript origins: http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# SMTP (gửi email quên mật khẩu) — có thể dùng Gmail App Password
