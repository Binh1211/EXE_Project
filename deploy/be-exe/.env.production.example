COMPOSE_PROJECT_NAME=exe-be-prod

API_HOST=api-vistory.treklink.site
TRAEFIK_NETWORK=treklink-edge
TRAEFIK_CERT_RESOLVER=letsencrypt
API_IMAGE=exe-be-api
IMAGE_TAG=latest
UPLOADS_VOLUME_NAME=exe-be-uploads

PORT=8080
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vistory?retryWrites=true&w=majority
CLIENT_URL=https://vistory-xi.vercel.app

JWT_ACCESS_SECRET=replace-with-real-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-real-random-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api-vistory.treklink.site/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vistory <noreply@example.com>"
